# ===== 日志配置 =====
# 日志级别: DEBUG（详细链路）/ INFO（关键节点，默认）/ WARNING / ERROR
LOG_LEVEL=INFO
# 日志文件路径（相对项目根目录，留空则只输出控制台）
LOG_FILE=logs/rag.log
LOG_FILE_MAX_MB=10
LOG_FILE_BACKUP_COUNT=5

# ===== Milvus 向量数据库（V3） =====
# 部署模式: "lite"(本地文件，零外部依赖) 或 "standalone"(Docker)
MILVUS_MODE=standalone
# Milvus URI: Lite 模式为本地文件路径；Standalone 模式为 http://localhost:19530
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=rag_collection

# ===== Embedding 配置（V5：bge-m3 via Ollama） =====
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
OLLAMA_BASE_URL=http://localhost:11434

# ===== LLM 配置（OpenAI 兼容接口） =====
# 阶跃星辰 step-3.7-flash / OpenAI gpt-4o-mini / 其他兼容模型
LLM_PROVIDER=openai-compatible
LLM_MODEL=step-3.7-flash
OPENAI_BASE_URL=https://api.stepfun.com/step_plan/v1
OPENAI_API_KEY=你的_API_KEY

# ===== 父子切分（V4 Small-to-Big） =====
PARENT_CHUNK_SIZE=1024
CHILD_CHUNK_SIZE=256
CHILD_OVERLAP=30
# 父块字符上限（防止异常父块撑爆 LLM 上下文）
MAX_PARENT_CHARS=4000

# ===== 检索配置 =====
TOP_K=4
# Hybrid 检索（V4-B+：向量 + BM25 RRF 融合）
HYBRID_SEARCH_ENABLED=true
HYBRID_VECTOR_TOP_K=20
HYBRID_BM25_TOP_K=20
HYBRID_RRF_K=60

# ===== Reranker（V5：Cross-encoder 二阶段精排） =====
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_MAX_LENGTH=512
# RERANK_TOP_K=4

# ===== 性能与离线 =====
# Embedding 批量大小（避免 Ollama 子进程 tokenize 压力过大）
EMBEDDING_BATCH_SIZE=16
# HuggingFace 离线模式（首次下载 Reranker 模型时设为 0）
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ===== 对象存储 =====
# 存储后端: "local"(本地文件系统) 或 "minio"(MinIO)
STORAGE_BACKEND=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-documents
MINIO_SECURE=false
MINIO_REGION=us-east-1

# ===== JWT 认证 =====
# 生产环境必须修改为随机字符串（至少 32 字符）
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===== 数据库（MySQL，库名 rag） =====
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/rag

# ===== Redis 对话缓存 =====
# ?protocol=2 强制 RESP2，兼容老版本 Redis
REDIS_URL=redis://localhost:6379/0?protocol=2
REDIS_CONVERSATION_TTL=1800
REDIS_CONVERSATION_MAX_MESSAGES=60

# ===== CORS =====
# 多个源用逗号分隔，不要用通配符 *
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ===== 文档上传目录 =====
DOCUMENTS_DIR=documents
