# ===== Milvus 向量数据库（V3） =====
# 部署模式: "lite"(本地文件，零外部依赖) 或 "standalone"(Docker)
MILVUS_MODE=lite
# Milvus URI: Lite 模式为本地文件路径；Standalone 模式为 http://localhost:19530
MILVUS_URI=milvus.db
# Collection 名称
MILVUS_COLLECTION=rag_collection

# Embedding 提供者: "local" (sentence-transformers) 或 "openai"
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# LLM 提供者: "openai", "anthropic", "ollama" 等（后续接入具体模型时修改）
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Ollama 配置（如果 LLM_PROVIDER=ollama）
OLLAMA_BASE_URL=http://localhost:11434

# 分块参数
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# 检索参数
TOP_K=4

# 文档上传目录
DOCUMENTS_DIR=documents

# ===== 对象存储 =====
# 存储后端: "local"(本地文件系统) 或 "minio"(MinIO)
STORAGE_BACKEND=minio
# MinIO 配置（STORAGE_BACKEND=minio 时生效）
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-documents
MINIO_SECURE=false
MINIO_REGION=us-east-1

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 数据库 (MySQL, 库名 rag)
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/rag

# Redis 对话缓存（?protocol=2 强制 RESP2，兼容老版本 Redis）
REDIS_URL=redis://localhost:6379/0?protocol=2
REDIS_CONVERSATION_TTL=1800
REDIS_CONVERSATION_MAX_MESSAGES=60
